# Frontend (Vite — solo en build)
VITE_API_URL=/api

# Backend (Railway inyecta DATABASE_URL al vincular Postgres)
# DATABASE_URL=postgresql://user:pass@host:5432/railway
# JWT_SECRET=generar_un_secreto_largo
# PORT=4000
# HOST=https://tu-dominio.up.railway.app
# CORS_ORIGINS=https://tu-dominio.up.railway.app
# TRUST_PROXY=1
# PGSSLMODE=require
# Local sin SSL:
# PGSSLMODE=disable

# Invitaciones por correo (admin crea usuarios)
# FRONTEND_URL=https://tu-dominio.com
# SMTP_HOST=smtp.ejemplo.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="LRV Admin <no-reply@tu-dominio.com>"
# JWT_EXPIRES_IN=12h
# INVITE_EXPIRY_HOURS=48
# RESET_TOKEN_EXPIRY_MINUTES=60

# Seed inicial (npm run seed en backend-node) — usuario admin por defecto
# ADMIN_EMAIL=lrventaser@gmail.com
# ADMIN_PASSWORD=LRV_Admin_2026!
