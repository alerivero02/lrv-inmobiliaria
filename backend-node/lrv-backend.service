[Unit]
Description=LRV Backend (Node.js)
After=network.target

[Service]
Type=simple
WorkingDirectory=/var/www/lrv/backend
Environment=NODE_ENV=production
ExecStart=/usr/bin/node /var/www/lrv/backend/server.js
Restart=always
RestartSec=3

# Seguridad básica
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target

