# Puerto del servidor
PORT=4000

# Secreto JWT (OBLIGATORIO en producción; generá uno fuerte)
JWT_SECRET=change-me-in-production

# Ruta a la base de datos SQLite
DB_PATH=./lrv.db

# URL base del servidor (para construir URLs de imágenes)
HOST=http://localhost:4000

# CORS allowlist (coma-separado). Ejemplo:
# CORS_ORIGINS=http://localhost:5173,https://tudominio.com
CORS_ORIGINS=

# Optimización de imágenes (subidas de admin)
# Formatos: webp (default) o avif
IMAGE_FORMAT=webp
# Ancho máximo (mantiene proporción). Default: 1920
IMAGE_MAX_WIDTH=1920
# Calidad 1-100. Default: 80
IMAGE_QUALITY=80
