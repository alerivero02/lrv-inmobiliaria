{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false
    }
  },
  "files": {
    "maxSize": 4194304,
    "includes": [
      "**/*",
      "!!**/node_modules/**",
      "!!**/dist/**",
      "!!**/.git/**",
      "!!**/uploads/**",
      "!!**/*.db",
      "!!**/*.db-*"
    ]
  }
}
