{
  "name": "lrv-inmobiliaria",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "npm run dev --prefix backend-node",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "dev:all": "docker compose up -d db && wait-on tcp:127.0.0.1:5433 -t 120000 && cross-env DATABASE_URL=postgresql://lrv:lrv@127.0.0.1:5433/lrv PGSSLMODE=disable JWT_SECRET=dev-local-jwt-secret-change-me CORS_ORIGINS=http://localhost:5173 FRONTEND_URL=http://localhost:5173 VITE_API_URL=/api concurrently -k -n api,web -c cyan,magenta \"npm run dev --prefix backend-node\" \"vite\"",
    "dev:all:sqlite": "cross-env JWT_SECRET=dev-local-jwt-secret-change-me CORS_ORIGINS=http://localhost:5173 FRONTEND_URL=http://localhost:5173 VITE_API_URL=/api concurrently -k -n api,web -c cyan,magenta \"npm run dev --prefix backend-node\" \"vite\"",
    "build": "node scripts/seo-assets.mjs && vite build",
    "preview": "vite preview",
    "lint": "biome lint .",
    "format": "biome format . --write"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@liedekef/fdatepicker": "^3.0.42",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/x-charts": "^8.28.0",
    "@mui/x-data-grid": "^8.28.0",
    "@mui/x-date-pickers": "^8.27.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-google-maps/api": "^2.20.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "^18.2.0",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "swiper": "^11.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "postcss": "^8.5.8",
    "shadcn": "^4.1.2",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.2",
    "vite": "^5.0.0",
    "wait-on": "^8.0.1",
    "yaml": "^2.8.3"
  }
}
